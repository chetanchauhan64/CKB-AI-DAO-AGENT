# Backend Environment Variables

# === CKB Network ===
CKB_RPC_URL=https://testnet.ckb.dev/rpc
CKB_INDEXER_URL=https://testnet.ckb.dev/indexer
CKB_NETWORK=testnet

# === Wallet (NEVER commit real keys) ===
# Private key WITHOUT 0x prefix
WALLET_PRIVATE_KEY=945663e7dd4ec255b81ffaf5fe0a1df81e9cdbd717fe27485f8147ab07f73a23

# --- AI AGENT SETTINGS ---
# Anthropic API Key (Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-opus-4-5

# === Server ===
PORT=3001
FRONTEND_URL=http://localhost:3000

# === Agent ===
# Rolling conversation window size
AGENT_MEMORY_WINDOW=20

# === Automation ===
# Cron schedule for DAO monitoring (default: every 30 minutes)
DAO_MONITOR_CRON=*/30 * * * *
# Epochs remaining in cycle before auto-harvest triggers
HARVEST_THRESHOLD_EPOCHS=5
# Enable auto-harvest by default (true/false)
AUTO_HARVEST_ENABLED=false
